# 2-bot (tikuvchilik) sozlamalari.
# MONGO_URI, REDIS_URL, QUEUE_PREFIX, WEB_PORT — docker-compose.yml da o'rnatilgan,
# bu yerda kerak emas.

BOT_TOKEN=your-tikuv-bot-token
DEFAULT_WELCOME=Xush kelibsiz! Tez orada yangiliklarni ulashamiz.
ADMIN_IDS=12345678
LOG_LEVEL=info

# Oddiy foydalanuvchi yozganda ko'rsatiladigan admin akkaunti (username, @ siz)
ADMIN_CONTACT=Shokir_tursun

# Sequence tugmalari bosilishini kuzatish (on/off)
SEQUENCE_CLICK_TRACKING=on

# Dashboard manzili va brauzer kaliti
WEBAPP_URL=https://naduakademy.duckdns.org
DASHBOARD_KEY=
